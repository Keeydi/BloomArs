{
  "expo": {
    "name": "BloomAR",
    "slug": "bloomar",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "bloomar",
    "jsEngine": "hermes",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FF5C8A"
    },
    "assetBundlePatterns": [
      "**/*",
      "assets/models/**/*.glb",
      "assets/models/textures/**/*.png"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bloomar.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow BloomAR to access your camera to scan flowers and visualize bouquets in AR.",
        "NSPhotoLibraryUsageDescription": "Allow BloomAR to save and export your bouquet designs.",
        "NSPhotoLibraryAddUsageDescription": "Allow BloomAR to save bouquet images to your photo library.",
        "NSLocationWhenInUseUsageDescription": "AR features require location for environment mapping and accurate placement."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF5C8A"
      },
      "package": "com.bloomar.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow BloomAR to access your camera to scan flowers and visualize bouquets in AR."
        }
      ],
      "expo-router",
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c0908a62-3968-4b8e-a559-b7330661bb66"
      }
    },
    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "url": null
    },
    "runtimeVersion": {
      "policy": "nativeVersion"
    }
  }
}
